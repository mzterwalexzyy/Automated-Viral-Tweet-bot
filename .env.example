# --- LLM providers (OpenAI-compatible), tried in order with fallback ---
# Add as many as you have; on rate limit/error it rolls to the next.
# Example uses NVIDIA NIM free models (https://build.nvidia.com, no card needed).
LLM1_BASE_URL=https://integrate.api.nvidia.com/v1
LLM1_KEY=nvapi-...
LLM1_MODEL=minimaxai/minimax-m3

# LLM2_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM2_KEY=nvapi-...
# LLM2_MODEL=deepseek-ai/deepseek-r1

# LLM3_BASE_URL=...
# LLM3_KEY=...
# LLM3_MODEL=...

# --- X / Twitter API (https://developer.x.com -> create app, enable Read+Write OAuth 1.0a) ---
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# --- Telegram (create bot with @BotFather, get token; get your chat id from @userinfobot) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Bot behavior ---
# Comma-separated topics to tweet about
TOPICS=tech,AI,startups,productivity
# How many drafts per day (sent to Telegram for approval, or auto-posted in auto mode)
DRAFTS_PER_DAY=4
# auto = post without approval, approve = require Telegram approval (recommended)
MODE=approve

# --- Video clipping ---
# Whisper model size: tiny|base|small|medium (bigger = better + slower on CPU)
WHISPER_MODEL=base
